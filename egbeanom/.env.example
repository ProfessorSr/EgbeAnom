# GoDaddy MySQL credentials are server-side only. Do not expose these in Flutter web.
MYSQL_HOST=localhost
MYSQL_DATABASE=YOUR_GODADDY_DATABASE_NAME
MYSQL_USER=YOUR_GODADDY_DATABASE_USER
MYSQL_PASSWORD=YOUR_GODADDY_DATABASE_PASSWORD
MYSQL_PORT=3306

# Flutter web can safely know the API route, but never the database password.
EGBEANOM_API_BASE=/api/index.php

# For local Chrome debug, run `npm run dev-api` from the repo root and use:
EGBEANOM_DEBUG_API_BASE=http://localhost:8787/api/index.php
